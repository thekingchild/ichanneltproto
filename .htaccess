# -------------------------------------------------------
#  iChannel – Apache Rewrite Rules
# -------------------------------------------------------

# Set the default home page
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ── 1. Redirect /index or /index.html → root / ─────────────────────────
  RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
  RewriteRule ^ / [R=301,L,NE]

  # ── 2. Canonical redirect: strip .html from all other URLs ─────────────
  # /contact.html → 301 permanent redirect to /contact
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L,NE]

  # ── 3. Internally serve the .html file for clean URLs ──────────────────
  # /contact → serves contact.html transparently (no redirect loop)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

</IfModule>

# ── 4. Custom 404 for everything else ──────────────────────────────────────
ErrorDocument 404 /404.html
