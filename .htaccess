# -------------------------------------------------------
#  iChannel – Apache Rewrite Rules
# -------------------------------------------------------

Options -Indexes
Options +FollowSymLinks

RewriteEngine On

# ── 1. Canonical redirect: strip .html from incoming URLs ──────────────────
# If someone visits /contact.html → 301 to /contact
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# ── 2. Internally serve the .html file for clean URLs ─────────────────────
# /contact  →  contact.html  (no redirect loop because THE_REQUEST check above)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# ── 3. Custom 404 for everything else ─────────────────────────────────────
ErrorDocument 404 /404.html
